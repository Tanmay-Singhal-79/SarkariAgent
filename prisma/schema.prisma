generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  phone          String         @unique
  name           String?
  language       String         @default("hi") // default hindi
  age            Int?
  state          String?
  district       String?
  income         Float?
  occupation     String?
  casteCategory  String?
  landOwnership  Float?
  isPremium      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  familyMembers  FamilyMember[]
  documents      Document[]
  applications   Application[]
  payments       Payment[]
  notifications  Notification[]
}

model FamilyMember {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  name         String
  relation     String
  age          Int
  gender       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Document {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  type         String      // Aadhaar, RationCard, etc.
  url          String      // S3 URL
  extractedData String?    // Data from OCR stored as JSON string
  createdAt    DateTime    @default(now())
}

model Scheme {
  id           String      @id @default(cuid())
  name         String
  description  String
  state        String?     // null if central
  minAge       Int?
  maxAge       Int?
  maxIncome    Float?
  categories   String      // Stored as comma separated string
  occupations  String      // Stored as comma separated string
  amount       Float?
  createdAt    DateTime    @default(now())

  applications Application[]
}

model Application {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  schemeId     String
  scheme       Scheme      @relation(fields: [schemeId], references: [id])
  status       String      @default("PENDING") // PENDING, SUBMITTED, APPROVED, REJECTED
  agentId      String?
  agent        Agent?      @relation(fields: [agentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  payments     Payment[]
}

model Payment {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  applicationId String
  application  Application @relation(fields: [applicationId], references: [id])
  amount       Float
  status       String      @default("COMPLETED")
  date         DateTime    @default(now())
}

model Notification {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  message      String
  type         String      // VOICE, SMS, WHATSAPP
  status       String      @default("SENT")
  createdAt    DateTime    @default(now())
}

model Agent {
  id           String      @id @default(cuid())
  name         String
  status       String      @default("IDLE") // IDLE, ACTIVE, ERROR
  tasksCompleted Int       @default(0)
  createdAt    DateTime    @default(now())
  
  applications Application[]
}
